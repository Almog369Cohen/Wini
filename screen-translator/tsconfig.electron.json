{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/electron",
    "rootDir": "electron",
    "lib": ["ES2022"]
  },
  "include": ["electron"],
  "exclude": ["node_modules", "dist", "src"]
}
